import { StyleSheet, TouchableOpacity, Alert, Text, View } from 'react-native';
import { useState, useEffect } from 'react';
import { Link, useRouter } from 'expo-router';
import AsyncStorage from '@react-native-async-storage/async-storage';
import { translations, Language } from './i18n';

const quizData = [
  {
    question: "JavaScriptはプログラミング言語である。",
    answer: true
  },
  {
    question: "HTMLはハイパーテキスト・マークランゲージを表している",
    answer: true
  },
  {
    question: "CSSはデータベース管理に使われている",
    answer: false
  }
];

export default function HomeScreen() {
  const [allQuestions, setAllQuestions] = useState(quizData);
  const [enabledQuestions, setEnabledQuestions] = useState(quizData);
  const [timerMinutes, setTimerMinutes] = useState(3);
  const [language, setLanguage] = useState<Language>('ja');
  const router = useRouter();

  // Load saved questions on component mount
  useEffect(() => {
    loadSavedQuestions();
    loadTimerSetting();
    loadLanguageSetting();
  }, []);

  const t = (key: keyof typeof translations.ja) => translations[language][key as keyof typeof translations.ja];

  const loadSavedQuestions = async () => {
    try {
      const savedQuestions = await AsyncStorage.getItem('userQuestions');
      if (savedQuestions) {
        const userQuestions = JSON.parse(savedQuestions);
        const combinedQuestions = [...quizData, ...userQuestions];
        setAllQuestions(combinedQuestions);
        setEnabledQuestions(combinedQuestions.filter(q => q.enabled !== false));
      }
    } catch (error) {
      console.error('Error loading questions:', error);
    }
  };

  const loadTimerSetting = async () => {
    try {
      const timerSetting = await AsyncStorage.getItem('timerSetting');
      if (timerSetting) {
        setTimerMinutes(parseInt(timerSetting));
      }
    } catch (error) {
      console.error('Error loading timer setting:', error);
    }
  };

  const loadLanguageSetting = async () => {
    try {
      const savedLanguage = await AsyncStorage.getItem('language');
      if (savedLanguage && (savedLanguage === 'ja' || savedLanguage === 'en')) {
        setLanguage(savedLanguage as Language);
      }
    } catch (error) {
      console.error('Error loading language setting:', error);
    }
  };

  const toggleLanguage = async () => {
    const newLanguage = language === 'ja' ? 'en' : 'ja';
    setLanguage(newLanguage);
    try {
      await AsyncStorage.setItem('language', newLanguage);
    } catch (error) {
      console.error('Error saving language setting:', error);
    }
  };

  return (
    <View style={styles.container}>
      <View style={styles.headerRow}>
        <Text style={styles.title}>{t('appTitle')}</Text>
        <TouchableOpacity style={styles.languageToggle} onPress={toggleLanguage}>
          <Text style={styles.languageText}>{language === 'ja' ? 'JP' : 'EN'}</Text>
        </TouchableOpacity>
      </View>
      
      {/* Stats Row */}
      <View style={styles.statsRow}>
        <View style={styles.statItem}>
          <Text style={styles.statNumber}>{allQuestions.length}</Text>
          <Text style={styles.statLabel}>{t('totalQuestions')}</Text>
        </View>
        <View style={styles.statItem}>
          <Text style={styles.statNumber}>{enabledQuestions.length}</Text>
          <Text style={styles.statLabel}>{t('enabled')}</Text>
        </View>
        <View style={styles.statItem}>
          <Text style={styles.statNumber}>{timerMinutes}m</Text>
          <Text style={styles.statLabel}>{t('timer')}</Text>
        </View>
      </View>
      
      {/* Icon Grid Navigation */}
      <View style={styles.iconGrid}>
        <TouchableOpacity style={styles.iconButton} onPress={() => router.push('/quiz')}>
          <View style={styles.iconContainer}>
            <Text style={styles.iconText}>▶</Text>
          </View>
          <Text style={styles.iconText}>{t('startQuiz')}</Text>
          <Text style={styles.subtitle}>{enabledQuestions.length} {t('questionsAvailable')}</Text>
        </TouchableOpacity>
        
        <TouchableOpacity style={styles.iconButton} onPress={() => router.push('/create')}>
          <View style={styles.iconContainer}>
            <Text style={styles.iconText}>+</Text>
          </View>
          <Text style={styles.iconText}>{t('create')}</Text>
          <Text style={styles.subtitle}>{t('manualOrAI')}</Text>
        </TouchableOpacity>
        
        <TouchableOpacity style={styles.iconButton} onPress={() => router.push('/manage')}>
          <View style={styles.iconContainer}>
            <Text style={styles.iconText}>⚙</Text>
          </View>
          <Text style={styles.iconText}>{t('manage')}</Text>
          <Text style={styles.subtitle}>{t('timerAndSettings')}</Text>
        </TouchableOpacity>
        
        <TouchableOpacity style={styles.iconButton} onPress={() => router.push('/browse')}>
          <View style={styles.iconContainer}>
            <Text style={styles.iconText}>📖</Text>
          </View>
          <Text style={styles.iconText}>{t('browse')}</Text>
          <Text style={styles.subtitle}>{t('viewAndEdit')}</Text>
        </TouchableOpacity>
      </View>
      
      {/* Quick Stats */}
      <View style={styles.statsContainer}>
        <Text style={styles.statsTitle}>{t('quickStats')}</Text>
        <Text style={styles.statsText}>
          {t('totalQuestions')}: {enabledQuestions.length}
        </Text>
        <Text style={styles.statsText}>
          {t('timerSetting')}: {timerMinutes} {t('min')}
        </Text>
      </View>
    </View>
  );
}

