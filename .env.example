# Firebase Configuration - コピーして .env を作成してください
# Firebase コンソール (https://console.firebase.google.com) から以下の値を取得して入力してください
REACT_APP_FIREBASE_API_KEY=your_actual_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=an-q-app.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=an-q-app
REACT_APP_FIREBASE_STORAGE_BUCKET=an-q-app.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=your_actual_app_id_here

# Gemini API (Google AI Studio から取得)
GEMINI_API_KEY=your_gemini_api_key_here

# Admin Settings
REACT_APP_ADMIN_EMAIL=your-admin@ga.ariake-nct.ac.jp

# App Settings
NODE_ENV=production
