{
  "name": "an-q",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "homepage": "https://taito-create.github.io/An-Q",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "npx expo export -p web --output-dir dist && node fix-paths.js",
    "build:clean": "node -e \"const fs=require('fs');const path=require('path');const distPath=path.join(__dirname,'dist');if(fs.existsSync(distPath)){fs.rmSync(distPath,{recursive:true,force:true});console.log('dist folder removed');}else{console.log('dist folder does not exist');}\"",

    "predeploy": "echo 'predeploy handled in deploy'",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@google/generative-ai": "^0.24.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@types/lodash.memoize": "^4.1.9",
    "expo": "^51.0.39",
    "expo-av": "~14.0.7",
    "expo-dev-client": "~4.0.29",
    "expo-notifications": "~0.28.9",
    "expo-pwa": "^0.0.127",
    "expo-router": "~3.5.14",
    "expo-status-bar": "~1.12.1",
    "firebase": "^12.13.0",
    "lodash.memoize": "^4.1.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-calendars": "^1.1314.0",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-web": "~0.19.6",
    "xdate": "^0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@types/react": "~18.2.79",
    "@types/react-dom": "~18.2.25",
    "@types/react-native": "^0.72.8",
    "gh-pages": "^6.3.0",
    "typescript": "~5.3.3"
  },
  "private": true
}
